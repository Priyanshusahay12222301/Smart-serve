{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/developer", "destination": "/developer/index.html" },
    { "source": "/developer/:path*", "destination": "/developer/index.html" },
    { "source": "/menu/:path*", "destination": "/index.html" },
    { "source": "/cart", "destination": "/index.html" },
    { "source": "/confirmation", "destination": "/index.html" },
    { "source": "/track/:path*", "destination": "/index.html" },
    { "source": "/:restaurantId([a-zA-Z0-9_-]+)", "destination": "/index.html" }
  ]
}
