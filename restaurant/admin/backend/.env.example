# Server Configuration
PORT=5002
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/smart-serve

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Demo Smart Admin Credentials (will be created on first run)
DEMO_SMART_ADMIN_EMAIL=admin@restaurant.com
DEMO_SMART_ADMIN_PASSWORD=admin123
DEMO_RESTAURANT_NAME=Delicious Bites
